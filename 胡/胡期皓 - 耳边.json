{
  "lyrics": [
    {
      "time": 14530,
      "text": "爱路过谁的耳边",
      "pinyin": "Ài lùguò shuí de ěr biān",
      "trans": "Cinta melewati telinga siapa"
    },
    {
      "time": 16650,
      "text": "谁装没听见",
      "pinyin": "Shuí zhuāng méi tīngjiàn",
      "trans": "Siapa yang pura-pura tak mendengar"
    },
    {
      "time": 18870,
      "text": "电话铃",
      "pinyin": "Diànhuà líng",
      "trans": "Nada dering telepon"
    },
    {
      "time": 19670,
      "text": "叮咚叮",
      "pinyin": "Dīng dōng dīng",
      "trans": "Ding dong ding"
    },
    {
      "time": 20650,
      "text": "像一首Old Love Song",
      "pinyin": "Xiàng yī shǒu Old Love Song",
      "trans": "Seperti sebuah Lagu Cinta Lama"
    },
    {
      "time": 22680,
      "text": "你是 白的雪 粉的天 弯的月 babe",
      "pinyin": "Nǐ shì bái de xuě fěn de tiān wān de yuè babe",
      "trans": "Kau adalah salju putih, langit merah muda, bulan sabit, babe"
    },
    {
      "time": 27340,
      "text": "琴弦轻抚指尖",
      "pinyin": "Qínxián qīng fǔ zhǐ jiān",
      "trans": "Senar gitar membelai lembut ujung jari"
    },
    {
      "time": 29260,
      "text": "音符跳跃在耳边",
      "pinyin": "Yīnfú tiàoyuè zài ěr biān",
      "trans": "Nada-nada melompat di telinga"
    },
    {
      "time": 31600,
      "text": "谱成了心愿",
      "pinyin": "Pǔ chéng le xīnyuàn",
      "trans": "Tersusun menjadi harapan hati"
    },
    {
      "time": 33500,
      "text": "趁着天",
      "pinyin": "Chènzhe tiān",
      "trans": "Mumpung langit"
    },
    {
      "time": 34570,
      "text": "还未变",
      "pinyin": "Hái wèi biàn",
      "trans": "Masih belum berubah"
    },
    {
      "time": 35300,
      "text": "唱这首New Love Song",
      "pinyin": "Chàng zhè shǒu New Love Song",
      "trans": "Menyanyikan Lagu Cinta Baru ini"
    },
    {
      "time": 37400,
      "text": "你是否也愿意",
      "pinyin": "Nǐ shìfǒu yě yuànyì",
      "trans": "Apakah kau juga bersedia"
    },
    {
      "time": 39470,
      "text": "改变这故事线With Me",
      "pinyin": "Gǎibiàn zhè gùshì xiàn With Me",
      "trans": "Mengubah alur cerita ini bersamaku"
    },
    {
      "time": 45010,
      "text": "Baby I 为了在茫茫人海让你更直观感受而为你写歌",
      "pinyin": "Baby I wèile zài mángmáng rén hǎi ràng nǐ gèng zhíguān gǎnshòu ér wèi nǐ xiě gē",
      "trans": "Baby aku menulis lagu untukmu agar kau bisa merasakannya lebih jelas di tengah lautan manusia"
    },
    {
      "time": 48680,
      "text": "所有的快乐的难过的委屈的伤心的幸福的I call it love",
      "pinyin": "Suǒyǒu de kuàilè de nánguò de wěiqu de shāngxīn de xìngfú de I call it love",
      "trans": "Semua yang bahagia, sedih, merasa bersalah, patah hati, dan beruntung, aku menyebutnya cinta"
    },
    {
      "time": 52310,
      "text": "我猜你也慢慢的慢慢的听懂了我给你谱写的歌",
      "pinyin": "Wǒ cāi nǐ yě mànmàn de mànmàn de tīng dǒng le wǒ gěi nǐ pǔxiě de gē",
      "trans": "Ku tebak kau juga perlahan-lahan mengerti lagu yang ku tulis untukmu"
    },
    {
      "time": 56120,
      "text": "Tonight I know it's Love",
      "pinyin": "Tonight I know it's Love",
      "trans": "Malam ini aku tahu ini Cinta"
    },
    {
      "time": 57910,
      "text": "女孩你太独特",
